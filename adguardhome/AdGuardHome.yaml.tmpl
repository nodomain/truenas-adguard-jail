# AdGuard Home configuration template (schema_version 33, AdGuard Home v0.107.x).
#
# This is an EXAMPLE, sanitized config-as-code source for the NAS AdGuard jail.
# All site-specific values (upstreams, blocklists, custom rules, rewrites) are
# generic placeholders — adapt them to your network.
#
# To keep your real, personal config out of version control:
#   1. copy this file to  adguardhome/AdGuardHome.local.tmpl
#   2. edit it with your actual settings
# `setup-adguard-jail.sh provision` prefers AdGuardHome.local.tmpl when present
# (it is gitignored), and falls back to this example otherwise.
#
# Placeholders substituted at provision time:
#   @@ADMIN_USER@@    - web UI admin username   (from ADGUARD_ADMIN_USER)
#   @@ADMIN_PWHASH@@  - bcrypt hash of the admin password (from ADGUARD_ADMIN_PASSWORD,
#                       or preserved from the jail when that is unset)
http:
  pprof:
    port: 6060
    enabled: false
  address: 0.0.0.0:80
  session_ttl: 720h
users:
  - name: @@ADMIN_USER@@
    password: @@ADMIN_PWHASH@@
auth_attempts: 5
block_auth_min: 15
http_proxy: ""
language: ""
theme: auto
dns:
  bind_hosts:
    - 0.0.0.0
    - "::"
  port: 53
  anonymize_client_ip: false
  # Rate limiting disabled (a single LAN-wide resolver can be busy).
  ratelimit: 0
  ratelimit_subnet_len_ipv4: 24
  ratelimit_subnet_len_ipv6: 56
  ratelimit_whitelist: []
  refuse_any: true
  # EXAMPLE upstreams. Replace with your preferred resolvers. The bracket syntax
  # sends specific domains to a specific server:
  #   [/lan/]192.168.1.1   -> resolve *.lan via the router
  #   [//]192.168.1.1      -> resolve unqualified / private names via the router
  upstream_dns:
    - https://dns.quad9.net/dns-query
    - https://cloudflare-dns.com/dns-query
    - "[/lan/]192.168.1.1"
    - "[//]192.168.1.1"
  upstream_dns_file: ""
  bootstrap_dns:
    - 1.1.1.1:53
    - 2606:4700:4700::1111
  fallback_dns:
    - 8.8.8.8
    - 8.8.4.4
    - 2001:4860:4860::8888
  upstream_mode: parallel
  fastest_timeout: 1s
  allowed_clients: []
  disallowed_clients: []
  blocked_hosts:
    - version.bind
    - id.server
    - hostname.bind
  trusted_proxies:
    - 127.0.0.0/8
    - ::1/128
  # DNS cache enabled (4 MB) — worth it on an always-on box.
  cache_enabled: true
  cache_size: 4194304
  cache_ttl_min: 0
  cache_ttl_max: 0
  cache_optimistic: false
  cache_optimistic_answer_ttl: 30s
  cache_optimistic_max_age: 12h
  bogus_nxdomain: []
  aaaa_disabled: false
  enable_dnssec: true
  edns_client_subnet:
    custom_ip: ""
    enabled: true
    use_custom: false
  max_goroutines: 300
  handle_ddr: true
  ipset: []
  ipset_file: ""
  bootstrap_prefer_ipv6: false
  upstream_timeout: 10s
  private_networks: []
  use_private_ptr_resolvers: true
  local_ptr_upstreams:
    - 192.168.1.1
  use_dns64: false
  dns64_prefixes: []
  serve_http3: false
  use_http3_upstreams: false
  serve_plain_dns: true
  hostsfile_enabled: true
  pending_requests:
    enabled: true
tls:
  enabled: false
  server_name: ""
  force_https: false
  port_https: 443
  port_dns_over_tls: 853
  port_dns_over_quic: 853
  port_dnscrypt: 0
  dnscrypt_config_file: ""
  allow_unencrypted_doh: false
  certificate_chain: ""
  private_key: ""
  certificate_path: ""
  private_key_path: ""
  strict_sni_check: false
querylog:
  dir_path: ""
  ignored: []
  interval: 24h
  size_memory: 1000
  enabled: true
  ignored_enabled: false
  file_enabled: true
statistics:
  dir_path: ""
  ignored: []
  interval: 2160h
  enabled: true
  ignored_enabled: false
# Blocklists: one curated all-in-one (HaGeZi Multi PRO) + a threat feed. The
# extra lists are disabled by default — flip enabled: true to use them.
filters:
  # All-in-one: ads, tracking, telemetry, phishing, malware, scam, cryptojacking,
  # and error trackers (Bugsnag/Crashlytics/Sentry). Balanced, low false-positives.
  - enabled: true
    url: https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/pro.txt
    name: HaGeZi Multi PRO
    id: 1800000001
  # Dedicated malware/phishing/scam threat intelligence feed.
  - enabled: true
    url: https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/tif.medium.txt
    name: HaGeZi Threat Intelligence Feeds (medium)
    id: 1800000002
  # Cookie banners / annoyances.
  - enabled: false
    url: https://raw.githubusercontent.com/AdguardTeam/FiltersRegistry/master/filters/filter_14_Annoyances/filter.txt
    name: AdGuard Annoyances Filter
    id: 1674258494
  # Stop clients bypassing your DNS via encrypted DNS / VPN / proxy / TOR.
  - enabled: false
    url: https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/doh-vpn-proxy-bypass.txt
    name: HaGeZi Encrypted DNS/VPN/Proxy Bypass
    id: 1800000003
  # Newly registered domains (last 7 days) - favoured by attackers. Higher FP risk.
  - enabled: false
    url: https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/nrd7.txt
    name: HaGeZi NRD (last 7 days)
    id: 1800000004
whitelist_filters: []
# EXAMPLE custom rules. AdGuard rule syntax:
#   ||ads.example.com^            block a domain
#   @@||example.com^$important    force-allow a domain (overrides blocklists)
user_rules:
  - "||ads.example.com^"
  - "@@||example.com^$important"
dhcp:
  enabled: false
  interface_name: ""
  local_domain_name: lan
  dhcpv4:
    gateway_ip: ""
    subnet_mask: ""
    range_start: ""
    range_end: ""
    lease_duration: 86400
    icmp_timeout_msec: 1000
    options: []
  dhcpv6:
    range_start: ""
    lease_duration: 86400
    ra_slaac_only: false
    ra_allow_slaac: false
filtering:
  blocking_ipv4: ""
  blocking_ipv6: ""
  # EXAMPLE blocked services (toggle the ones you want network-wide).
  blocked_services:
    schedule:
      time_zone: Local
    ids: []
  protection_disabled_until: null
  safe_search:
    enabled: false
    bing: true
    duckduckgo: true
    ecosia: true
    google: true
    pixabay: true
    yandex: true
    youtube: true
  blocking_mode: nxdomain
  parental_block_host: family-block.dns.adguard.com
  safebrowsing_block_host: standard-block.dns.adguard.com
  # EXAMPLE DNS rewrites: point a local domain at an internal host.
  rewrites:
    - domain: "*.example.lan"
      answer: 192.168.1.2
      enabled: true
    - domain: example.lan
      answer: 192.168.1.2
      enabled: true
  safe_fs_patterns:
    - /var/db/adguardhome/userfilters/*
  safebrowsing_cache_size: 1048576
  safesearch_cache_size: 1048576
  parental_cache_size: 1048576
  cache_time: 30
  filters_update_interval: 24
  blocked_response_ttl: 10
  filtering_enabled: true
  rewrites_enabled: true
  parental_enabled: false
  safebrowsing_enabled: true
  protection_enabled: true
clients:
  runtime_sources:
    whois: true
    arp: true
    rdns: true
    dhcp: true
    hosts: true
  persistent: []
log:
  enabled: true
  file: ""
  max_backups: 0
  max_size: 100
  max_age: 3
  compress: false
  local_time: false
  verbose: false
os:
  group: ""
  user: ""
  rlimit_nofile: 0
schema_version: 33
